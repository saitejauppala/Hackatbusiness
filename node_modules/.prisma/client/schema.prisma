generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Route {
  id          String     @id @default(uuid())
  source      String
  destination String
  distance    Float
  baseCost    Float
  createdAt   DateTime   @default(now())
  shipments   Shipment[]
  risks       Risk[]
}

model Shipment {
  id        String   @id @default(uuid())
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id])
  status    String
  eta       DateTime
  createdAt DateTime @default(now())
}

model Risk {
  id         String   @id @default(uuid())
  routeId    String
  route      Route    @relation(fields: [routeId], references: [id])
  weather    String
  traffic    String
  news       String
  demand     String
  finalScore Float
  createdAt  DateTime @default(now())
}

model IngestionLog {
  id        String   @id @default(uuid())
  source    String
  type      String
  value     Json
  hash      String   @unique
  timestamp DateTime
  createdAt DateTime @default(now())
}
